{
  "name": "text-wind",
  "version": "1.7.0",
  "description": "Architectural text typography for Tailwind CSS. No breakpoints, no config edits, no rebuilds.",
  "license": "MIT",
  "author": "textwind contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohd-Bilal-exe/fluidwind.git"
  },
  "bugs": {
    "url": "https://github.com/mohd-Bilal-exe/fluidwind/issues"
  },
  "homepage": "https://textwind.vercel.app",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "release": "npm run build && npm test && npm run typecheck"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "plugin",
    "typography",
    "fluid",
    "responsive",
    "clamp",
    "type-system",
    "design-system",
    "css",
    "brutalist",
    "layout"
  ],
  "peerDependencies": {
    "tailwindcss": ">=3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "eslint": "^9.24.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.5",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.2"
  }
}
